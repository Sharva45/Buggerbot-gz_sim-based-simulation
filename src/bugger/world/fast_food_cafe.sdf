        </inertial>
      </link>
    </model>

    <!-- Storage shelf kitchen -->
    <model name="kitchen_shelf">
      <static>true</static>
      <pose>-7 -7 1.0 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>0.4 2.0 2.0</size></box></geometry>
          <surface><friction><ode><mu>0.6</mu><mu2>0.6</mu2></ode></friction></surface>
