    <!-- Refrigerator -->
    <model name="refrigerator">
      <static>true</static>
      <pose>4 -7.5 1.0 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>0.8 0.8 2.0</size></box></geometry>
