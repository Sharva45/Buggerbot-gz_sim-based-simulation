      </link>
    </model>

    <!-- SERVICE COUNTER (main ordering counter) -->
    <model name="service_counter">
      <static>true</static>
      <pose>0 -4 0.55 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>6 0.8 1.1</size></box></geometry>
          <surface><friction><ode><mu>0.7</mu><mu2>0.7</mu2></ode></friction></surface>
        </collision>
        <visual name="vis">
          <geometry><box><size>6 0.8 1.1</size></box></geometry>
          <material>
            <ambient>0.2 0.2 0.22 1</ambient>
            <diffuse>0.2 0.2 0.22 1</diffuse>
