    <!-- KITCHEN AREA EQUIPMENT -->
    <!-- Cooking station -->
    <model name="cooking_station">
      <static>true</static>
      <pose>0 -7 0.45 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>3.0 1.0 0.9</size></box></geometry>
          <surface><friction><ode><mu>0.7</mu><mu2>0.7</mu2></ode></friction></surface>
        </collision>
