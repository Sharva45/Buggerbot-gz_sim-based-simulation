        </inertial>
      </link>
    </model>

    <!-- KITCHEN PARTITION WALL (separates kitchen from seating area) -->
    <model name="kitchen_partition_left">
      <static>true</static>
      <pose>-3.5 -5.5 2.0 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>6.8 0.2 4.0</size></box></geometry>
          <surface><friction><ode><mu>0.8</mu><mu2>0.8</mu2></ode></friction></surface>
        </collision>
        <visual name="vis">
          <geometry><box><size>6.8 0.2 4.0</size></box></geometry>
          <material>
            <ambient>0.85 0.82 0.78 1</ambient>
            <diffuse>0.85 0.82 0.78 1</diffuse>
            <specular>0.15 0.15 0.15 1</specular>
          </material>
        </visual>
        <inertial>
          <mass>200</mass>
          <inertia><ixx>1</ixx><iyy>1</iyy><izz>1</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
