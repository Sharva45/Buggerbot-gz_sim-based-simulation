    <!-- WALL EAST -->
    <model name="wall_east">
      <static>true</static>
      <pose>10 0 2.0 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>0.2 18 4.0</size></box></geometry>
          <surface><friction><ode><mu>0.8</mu><mu2>0.8</mu2></ode></friction></surface>
        </collision>
        <visual name="vis">
