<?xml version="1.0" ?>
<sdf version="1.9">
  <world name="fast_food_cafe">

    <plugin filename="gz-sim-physics-system"
            name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-sensors-system"
            name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-user-commands-system"
            name="gz::sim::systems::UserCommands"/>

    <physics name="default_physics" type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
      <gravity>0 0 -9.81</gravity>
      <ode>
        <solver>
          <type>quick</type>
          <iters>50</iters>
          <sor>1.3</sor>
          <use_dynamic_moi_rescaling>true</use_dynamic_moi_rescaling>
        </solver>
        <constraints>
          <cfm>0.0</cfm>
          <erp>0.2</erp>
          <contact_max_correcting_vel>100.0</contact_max_correcting_vel>
          <contact_surface_layer>0.001</contact_surface_layer>
        </constraints>
      </ode>
    </physics>

    <scene>
      <ambient>0.4 0.4 0.4 1.0</ambient>
      <background>0.7 0.7 0.7 1.0</background>
      <shadows>true</shadows>
    </scene>

    <light name="sun" type="directional">
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
      <cast_shadows>true</cast_shadows>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
    </light>

    <light name="ceiling_light_center" type="point">
      <pose>0 0 3.8 0 0 0</pose>
      <diffuse>1.0 0.98 0.9 1</diffuse>
      <specular>0.3 0.3 0.3 1</specular>
      <cast_shadows>false</cast_shadows>
      <attenuation>
        <range>12</range>
        <constant>0.4</constant>
        <linear>0.1</linear>
        <quadratic>0.02</quadratic>
      </attenuation>
    </light>

    <light name="ceiling_light_seating_1" type="point">
      <pose>4 3 3.8 0 0 0</pose>
      <diffuse>1.0 0.97 0.88 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <cast_shadows>false</cast_shadows>
      <attenuation>
        <range>8</range>
        <constant>0.5</constant>
        <linear>0.12</linear>
        <quadratic>0.025</quadratic>
      </attenuation>
    </light>

    <light name="ceiling_light_seating_2" type="point">
      <pose>-4 3 3.8 0 0 0</pose>
      <diffuse>1.0 0.97 0.88 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <cast_shadows>false</cast_shadows>
      <attenuation>
        <range>8</range>
        <constant>0.5</constant>
        <linear>0.12</linear>
        <quadratic>0.025</quadratic>
      </attenuation>
    </light>

    <light name="ceiling_light_counter" type="point">
      <pose>0 -4 3.8 0 0 0</pose>
      <diffuse>1.0 1.0 0.95 1</diffuse>
      <specular>0.4 0.4 0.4 1</specular>
      <cast_shadows>false</cast_shadows>
      <attenuation>
        <range>8</range>
        <constant>0.3</constant>
        <linear>0.08</linear>
        <quadratic>0.015</quadratic>
      </attenuation>
    </light>

    <light name="kitchen_light" type="point">
      <pose>0 -7 3.8 0 0 0</pose>
      <diffuse>1.0 1.0 1.0 1</diffuse>
      <specular>0.5 0.5 0.5 1</specular>
      <cast_shadows>false</cast_shadows>
      <attenuation>
        <range>6</range>
        <constant>0.3</constant>
        <linear>0.1</linear>
        <quadratic>0.02</quadratic>
      </attenuation>
    </light>

    <!-- FLOOR -->
    <model name="floor">
      <static>true</static>
      <pose>0 0 0 0 0 0</pose>
      <link name="floor_link">
        <collision name="floor_collision">
          <geometry>
            <box><size>20 18 0.1</size></box>
          </geometry>
          <surface>
            <contact>
              <ode>
                <kp>1e6</kp>
                <kd>1e2</kd>
              </ode>
            </contact>
            <friction>
              <ode>
                <mu>0.9</mu>
                <mu2>0.9</mu2>
              </ode>
            </friction>
            <bounce>
              <restitution_coefficient>0.0</restitution_coefficient>
              <threshold>1e6</threshold>
            </bounce>
          </surface>
        </collision>
        <visual name="floor_visual">
          <geometry>
            <box><size>20 18 0.1</size></box>
          </geometry>
          <material>
            <ambient>0.85 0.82 0.78 1</ambient>
            <diffuse>0.85 0.82 0.78 1</diffuse>
            <specular>0.3 0.3 0.3 1</specular>
          </material>
        </visual>
        <inertial>
          <mass>1000</mass>
          <inertia>
            <ixx>1</ixx><iyy>1</iyy><izz>1</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
      </link>
    </model>

    <!-- CEILING -->
    <model name="ceiling">
      <static>true</static>
      <pose>0 0 4.0 0 0 0</pose>
      <link name="ceiling_link">
        <collision name="ceiling_collision">
          <geometry>
            <box><size>20 18 0.1</size></box>
          </geometry>
        </collision>
        <visual name="ceiling_visual">
          <geometry>
            <box><size>20 18 0.1</size></box>
          </geometry>
          <material>
            <ambient>0.95 0.95 0.95 1</ambient>
            <diffuse>0.95 0.95 0.95 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
        <inertial>
          <mass>1000</mass>
          <inertia>
            <ixx>1</ixx><iyy>1</iyy><izz>1</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
      </link>
    </model>

    <!-- WALL NORTH -->
    <model name="wall_north">
      <static>true</static>
      <pose>0 9 2.0 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>20 0.2 4.0</size></box></geometry>
          <surface>
            <friction><ode><mu>0.8</mu><mu2>0.8</mu2></ode></friction>
          </surface>
        </collision>
        <visual name="vis">
          <geometry><box><size>20 0.2 4.0</size></box></geometry>
          <material>
            <ambient>0.92 0.88 0.82 1</ambient>
            <diffuse>0.92 0.88 0.82 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
        <inertial>
          <mass>500</mass>
          <inertia><ixx>1</ixx><iyy>1</iyy><izz>1</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
        </inertial>
      </link>
    </model>

    <!-- WALL SOUTH (with entrance gap: two segments) -->
    <model name="wall_south_left">
      <static>true</static>
      <pose>-5.5 -9 2.0 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>9 0.2 4.0</size></box></geometry>
          <surface><friction><ode><mu>0.8</mu><mu2>0.8</mu2></ode></friction></surface>
        </collision>
        <visual name="vis">
