            <ambient>0.92 0.88 0.82 1</ambient>
            <diffuse>0.92 0.88 0.82 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
        <inertial>
          <mass>300</mass>
          <inertia><ixx>1</ixx><iyy>1</iyy><izz>1</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
        </inertial>
      </link>
    </model>

    <model name="wall_south_right">
      <static>true</static>
      <pose>5.5 -9 2.0 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>9 0.2 4.0</size></box></geometry>
          <surface><friction><ode><mu>0.8</mu><mu2>0.8</mu2></ode></friction></surface>
        </collision>
        <visual name="vis">
