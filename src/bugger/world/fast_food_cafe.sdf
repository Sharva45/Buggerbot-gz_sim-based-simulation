          <inertia><ixx>10</ixx><iyy>10</iyy><izz>10</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
        </inertial>
      </link>
    </model>

    <!-- Counter top surface -->
    <model name="counter_top">
      <static>true</static>
      <pose>0 -4 1.11 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>6.1 0.9 0.05</size></box></geometry>
        </collision>
