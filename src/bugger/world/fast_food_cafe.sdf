        </inertial>
      </link>
    </model>

    <!-- CASH REGISTER on counter -->
    <model name="cash_register_1">
      <static>true</static>
      <pose>-1.5 -4 1.25 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>0.3 0.25 0.25</size></box></geometry>
