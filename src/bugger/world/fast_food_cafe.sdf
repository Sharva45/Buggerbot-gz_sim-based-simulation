        <inertial>
          <mass>300</mass>
          <inertia><ixx>1</ixx><iyy>1</iyy><izz>1</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
        </inertial>
      </link>
    </model>

    <!-- Door lintel south -->
    <model name="wall_south_lintel">
      <static>true</static>
      <pose>0 -9 3.5 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>2 0.2 1.0</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>2 0.2 1.0</size></box></geometry>
          <material>
            <ambient>0.92 0.88 0.82 1</ambient>
            <diffuse>0.92 0.88 0.82 1</diffuse>
