      <pose>0.0 0.0 0 0 0 0</pose>
    </include>

    <include>
      <name>table_B3</name>
      <uri>https://fuel.gazebosim.org/1.0/openrobotics/models/Table</uri>
      <pose>0.0 3.0 0 0 0 0</pose>
    </include>

    <!-- Row C (narrower, near east wall) -->
    <include>
      <name>table_C1</name>
      <uri>https://fuel.gazebosim.org/1.0/openrobotics/models/Table</uri>
      <pose>4.0 -1.5 0 0 0 0</pose>
    </include>

    <include>
      <name>table_C2</name>
      <uri>https://fuel.gazebosim.org/1.0/openrobotics/models/Table</uri>
      <pose>4.0 1.5 0 0 0 0</pose>
    </include>

    <!-- ═══════════════════════════════════════════════
         CHAIRS — Fuel model
         https://fuel.gazebosim.org/1.0/openrobotics/models/Chair

         Chair seat height: ~0.44 m (legs rest on z = 0)
         Offset from table centre: ±0.65 m (N/S/E/W)
         4 chairs per table × 8 tables = 32 chairs
         (tables C1/C2 against east wall get 3 chairs;
          east side omitted to avoid wall clash)
    ═══════════════════════════════════════════════ -->

    <!-- ── Table A1 chairs ── -->
    <include>
      <name>chair_A1_N</name>
      <uri>https://fuel.gazebosim.org/1.0/openrobotics/models/Chair</uri>
